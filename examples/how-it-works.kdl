// How Sceno works — source for README diagram (render with sceno render)
diagram title="How Sceno Works" subtitle="One KDL file → validate → render → polished exports" layout=auto style=polished gap=24 padding=24 {

  shape actor author "You or\nAI Agent" icon=user fill="#f1f5f9" at=0,0
  shape document spec "KDL spec\n(.kdl file)" fill="#dbeafe" at=1,0

  shape box validate "sceno validate\n--json" icon=shield fill="#ede9fe" at=2,0
  shape box describe "sceno describe\n(optional)" icon=info fill="#fef3c7" at=3,0
  shape box render "sceno render\n--all" icon=workflow fill="#d1fae5" at=4,0

  shape cloud outputs "SVG · PNG · PDF\nHTML · Slides" icon=cloud fill="#ffedd5" at=5,0

  edge author -> spec fromSide=right toSide=left label="write"
  edge spec -> validate fromSide=right toSide=left
  edge validate -> describe fromSide=right toSide=left label="ok?"
  edge describe -> render fromSide=right toSide=left
  edge render -> outputs fromSide=right toSide=left label="export"
}
