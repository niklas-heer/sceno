// How Sceno works — source for README diagram (render with sceno render)
diagram title="How Sceno Works" subtitle="KDL → validate → advise → describe → render → export" layout=auto style=polished gap=40 padding=36 {

  shape box author "You or\nAI Agent" icon=user iconPos=top-left fill="#f1f5f9" at=0,0
  shape document spec "KDL spec\n(.kdl file)" fill="#dbeafe" at=1,0

  shape box validate "sceno validate\n--json" icon=shield iconPos=top-left fill="#ede9fe" at=2,0
  shape box advise "sceno advise\nvisual rules" icon=info iconPos=top-left fill="#fef3c7" at=3,0
  shape box describe "sceno describe\nlayout check" icon=api iconPos=top-left fill="#e0e7ff" at=4,0
  shape box render "sceno render\n--all" icon=workflow iconPos=top-left fill="#d1fae5" at=5,0

  shape cloud outputs "SVG · PNG · PDF\nHTML · Slides" icon=cloud iconPos=top-left fill="#ffedd5" at=6,0

  edge author -> spec fromSide=right toSide=left label="write"
  edge spec -> validate fromSide=right toSide=left
  edge validate -> advise fromSide=right toSide=left label="ok?"
  edge advise -> describe fromSide=right toSide=left
  edge describe -> render fromSide=right toSide=left
  edge render -> outputs fromSide=right toSide=left label="export"
}
